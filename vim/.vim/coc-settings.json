// vim: ft=jsonc
{
    "languageserver": {
        "golang": {
            "command": "gopls",
            "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
            "filetypes": ["go"],
            "initializationOptions": {
                "usePlaceholders": true
            }
        }
    },
    "tsserver.filetypes": [
        "typescript",
        "typescriptreact",
        "javascript",
        "javascriptreact"
    ],
    "clangd.enabled": true,
    "clangd.path": "/home/sma/Projects/lab37/.toolchain/sysroot/bin/clangd",
    "clangd.arguments": [
        "--background-index",
        "--compile-commands-dir=/home/sma/Projects/lab37/build",
        "--clang-tidy",
        "--completion-style=detailed"
    ],
    "[cpp]": {
        "inlayHint.enable": false
    },
    "tsserver.maxTsServerMemory": 8192,
    "volar.maxTsServerMemory": 8192,
    "volar.tsPlugin": true,
    "volar.takeOverMode": false,
    "volar.filetypes": ["vue"],
    "pyright.disableDiagnostics": true,
    "pyright.inlayHints.parameterTypes": false,
    "pyright.inlayHints.variableTypes": false,
    "pyright.organizeimports.provider": "ruff",
    "python.formatting.provider": "ruff",
    "python.linting.ruffEnabled": true,
    "python.analysis.diagnosticSeverityOverrides": {
        // Turn off diagnostics used by Pyright because we use Ruff for linting
        "reportPrivateImportUsage": false,
        "reportUndefinedVariable": false
    },
    "[python,java]": {
        "coc.preferences.formatOnSave": true
    },
    "svelte.enable-ts-plugin": true
}

